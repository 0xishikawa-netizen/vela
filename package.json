{
  "name": "vela",
  "version": "0.1.0",
  "description": "Vela — local-first video editor",
  "main": "out/main/main.js",
  "type": "module",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/clear-electron-run-as-node.mjs dev",
    "build": "node scripts/clear-electron-run-as-node.mjs build",
    "preview": "node scripts/clear-electron-run-as-node.mjs preview",
    "package:mac": "npm run build && node scripts/clear-electron-run-as-node.mjs exec npx electron-builder --mac --config electron-builder.json",
    "package:win": "npm run build && node scripts/clear-electron-run-as-node.mjs exec npx electron-builder --win --config electron-builder.json",
    "fixture:phase-a:media": "node scripts/generate-phase-a-media.mjs",
    "fixture:phase-a:prepare": "node scripts/prepare-phase-a-fixture-json.mjs",
    "fixture:phase-a:export": "node scripts/export-phase-a-fixtures.mjs",
    "fixture:phase-a:check": "node scripts/check-phase-a-export.mjs",
    "fixture:phase-a:check-all": "node scripts/check-phase-a-export.mjs --out-dir fixtures/export/phase-a/out --prepared-dir fixtures/export/phase-a/prepared --epsilon 0.65",
    "fixture:phase-a:verify": "npm run fixture:phase-a:media && npm run fixture:phase-a:prepare && npm run build && npm run fixture:phase-a:export && npm run fixture:phase-a:check-all",
    "fixture:phase-a:verify:relaxed": "node scripts/run-phase-a-verify-relaxed.mjs",
    "fixture:phase-b:media": "npm run fixture:phase-a:media",
    "fixture:phase-b:prepare": "node scripts/prepare-phase-b-fixture-json.mjs",
    "fixture:phase-b:export": "node scripts/export-phase-b-fixtures.mjs",
    "fixture:phase-b:check": "node scripts/check-phase-b-export.mjs --out-dir fixtures/export/phase-b/out --prepared-dir fixtures/export/phase-b/prepared --epsilon 0.65",
    "fixture:phase-b:check-all": "npm run fixture:phase-b:check",
    "fixture:phase-b:verify": "npm run fixture:phase-b:media && npm run fixture:phase-b:prepare && npm run build && npm run fixture:phase-b:export && npm run fixture:phase-b:check-all",
    "check:waveform": "node scripts/check-waveform.mjs",
    "check:preview-look": "node scripts/check-preview-look.mjs",
    "check:lut-cube": "node scripts/check-lut-cube.mjs",
    "check:export-encoder": "node scripts/check-export-encoder.mjs",
    "check:export-presets": "node scripts/check-export-presets.mjs",
    "check:export-diagnostics": "node scripts/check-export-diagnostics.mjs",
    "check:export-platform-smoke-doc": "node scripts/check-export-platform-smoke-doc.mjs",
    "check:whisper-local-smoke-doc": "node scripts/check-whisper-local-smoke-doc.mjs",
    "smoke:whisper-local:electron": "node scripts/run-smoke-whisper-local-electron.cjs",
    "check:subtitles": "node scripts/check-subtitles.mjs",
    "check:transcription": "node scripts/check-transcription.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "immer": "^10.1.1",
    "konva": "^9.3.20",
    "nodejs-whisper": "^0.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-konva": "^19.0.3",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@swc/core": "^1.11.16",
    "@tailwindcss/vite": "^4.1.4",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
