{
  "name": "vela",
  "version": "0.1.0",
  "description": "Vela — local-first video editor",
  "main": "out/main/main.js",
  "type": "module",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/clear-electron-run-as-node.mjs dev",
    "build": "node scripts/clear-electron-run-as-node.mjs build",
    "preview": "node scripts/clear-electron-run-as-node.mjs preview",
    "package:mac": "npm run build && node scripts/clear-electron-run-as-node.mjs exec npx electron-builder --mac --config electron-builder.json",
